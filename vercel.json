{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/demo.html" },
    { "source": "/r/:room", "destination": "/demo.html?room=:room" }
  ],
  "headers": [
    {
      "source": "/demo.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
